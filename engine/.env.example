# Copy to .env and fill in real values. `.env` is gitignored; THIS file is committed as
# documentation ONLY — never put real secrets here.
OPENALEX_API_KEY=
FEATHERLESS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Qwen Cloud (Alibaba Model Studio) — the multimodal intake path.
# BASE URL is account/region dependent and Alibaba's docs disagree with each other. Verified
# 2026-07-16: only dashscope-intl authenticated our key; dashscope.aliyuncs.com and
# dashscope-us.aliyuncs.com both returned 401. A workspace-scoped form also exists:
#   https://{WorkspaceId}.ap-southeast-1.maas.aliyuncs.com/compatible-api/v1
# Get the value from YOUR Model Studio console rather than copying a doc page.
#
# NOTE: a valid key is not enough. Model Studio > Model Inference must be ACTIVATED on the account
# (balance >= 0), or every model returns 403 AccessDenied.Unpurchased even though GET /models lists it.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_INTAKE_MODEL=qwen3.7-plus
QWEN_RERANK_MODEL=qwen3-rerank
# Which provider serves intake: qwen (default/shipped) | openai | featherless (Q2 baselines only).
BRUCE_INTAKE_PROVIDER=qwen

# Google Calendar — real execution + read-back verification (bruce_engine/calendar_adapter.py).
# Bruce supplies its own deterministic event id, so a retried insert is rejected by Google with 409
# and execution happens exactly once. Verification requires an independent events.get read-back.
# Create an OAuth client (Desktop app) in Google Cloud Console, consent once with scope
# https://www.googleapis.com/auth/calendar.events, and store the resulting refresh token here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Raw-content retention window in days (default 30 if unset). See bruce_engine/retention.py.
BRUCE_RAW_RETENTION_DAYS=

# Phase 1.5 — auth + persistence. For real auth set BRUCE_JWT_SECRET (HS256) or BRUCE_JWKS_URL (RS256/ES256).
BRUCE_JWT_SECRET=
BRUCE_JWKS_URL=
BRUCE_JWT_AUDIENCE=
BRUCE_DATABASE_URL=
BRUCE_APP_DATABASE_URL=
