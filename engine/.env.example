# Copy to .env and fill in real values. `.env` is gitignored; THIS file is committed as
# documentation ONLY — never put real secrets here.

# --- REQUIRED (production) ---------------------------------------------------------------------
# OpenAI powers every synchronous student-facing step: vision transcription, structured extraction,
# drafting, and verification. Bruce does not run without it.
OPENAI_API_KEY=
# Grounded opportunity discovery (OpenAlex). Required for the outreach path.
OPENALEX_API_KEY=

# --- OPTIONAL / OFFLINE ------------------------------------------------------------------------
# Featherless (open-weight Qwen) is OFFLINE-ONLY: eval, batch, model comparison, overnight
# backfills. It is DISABLED by default and never serves a production request (its serverless
# latency has a multi-minute cold-start tail). Leave the flag empty in production. To use it in
# an offline job, set BRUCE_ENABLE_FEATHERLESS=1 AND provide the key.
BRUCE_ENABLE_FEATHERLESS=
FEATHERLESS_API_KEY=
# Reserved for a future flag-gated Claude fallback; unused today.
ANTHROPIC_API_KEY=
# Optional cost-estimate overrides for telemetry (USD per 1M tokens), e.g.:
# BRUCE_RATE_GPT_5_4_MINI_IN=0.25  BRUCE_RATE_GPT_5_4_MINI_OUT=2.00

# Google Calendar — real execution + read-back verification (bruce_engine/calendar_adapter.py).
# Bruce supplies its own deterministic event id, so a retried insert is rejected by Google with 409
# and execution happens exactly once. Verification requires an independent events.get read-back.
# Create an OAuth client (Desktop app) in Google Cloud Console, consent once with scope
# https://www.googleapis.com/auth/calendar.events, and store the resulting refresh token here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Raw-content retention window in days (default 30 if unset). See bruce_engine/retention.py.
BRUCE_RAW_RETENTION_DAYS=

# Phase 1.5 — auth + persistence. For real auth set BRUCE_JWT_SECRET (HS256) or BRUCE_JWKS_URL (RS256/ES256).
BRUCE_JWT_SECRET=
BRUCE_JWKS_URL=
BRUCE_JWT_AUDIENCE=
BRUCE_DATABASE_URL=
BRUCE_APP_DATABASE_URL=
